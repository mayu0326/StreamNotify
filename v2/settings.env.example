
# =============================================
# settings.env.example - 設定ファイルサンプル
#
# このファイルを settings.env にコピーし、各値を必ず設定してください。
#
# ⚠️ 注意: settings.env は個人情報（ID・パスワード・APIキー）を含むため、
#         公開リポジトリや共有環境には絶対に含めないでください。
#         Git管理外にしてください（.gitignore推奨）。
#
# 必須項目は「=」の右側に値を記入してください。
# サンプル記入例も参考にしてください。
# =============================================

# =============================
# 基本設定
# =============================

# 監視対象のYouTubeチャンネルID
#YouTubeAPI連携プラグイン未導入時はUCから始まるIDのみ設定可能です。
YOUTUBE_CHANNEL_ID=

# YouTubeのポーリング間隔（分単位、最小5分=5。例: 30で30分ごと。デフォルト: 5、推奨: 10）
POLL_INTERVAL_MINUTES=10

# アプリケーション動作モード（normal / auto_post / dry_run / collect）
# 初回起動時やDBが読み込めない場合はcollectモードで起動しDBの再生成を実行します。
APP_MODE=normal

# デバッグモード（true/false）- デバッグ情報を詳細に出力します
DEBUG_MODE=false

# タイムゾーン設定（例: Asia/Tokyo, UTC, America/New_York, Europe/London）
# "system" を指定すると、実行環境のシステムタイムゾーンを自動的に使用します。
# 無効な値や空の場合はシステムタイムゾーンまたはUTCにフォールバックします。
TIMEZONE=system

# Blueskyのユーザー名 (例: your-handle.bsky.social or 独自ドメイン等ご利用中のID)
BLUESKY_USERNAME=

# Blueskyのアプリパスワード (Blueskyの設定画面で発行してください)
BLUESKY_PASSWORD=

# Blueskyへの投稿を有効にするか（True/False）
BLUESKY_POST_ENABLED=True

# -------------------------------------------------- #
# 以下は、v2対応のプラグイン用設定です。
# プラグインを導入しない場合は設定する必要がありません。
# -------------------------------------------------- #

# =============================
# Bluesky 機能拡張プラグインの設定（実装準備中）
# =============================
# Bluesky投稿時に使用する画像ファイルのパス(画像未設定時の共通パス)
# BLUESKY_IMAGE_PATH=images\default\noimage.png
# 動画投稿通知用テンプレートファイル(YouTube動画)
# BLUESKY_YT_NEW_VIDEO_TEMPLATE_PATH=templates\YouTube\yt_new_video_template.txt

# =============================
# ログ設定拡張プラグインの設定
# =============================
# グローバルログレベル設定
# コンソール出力するログレベル (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL_CONSOLE=INFO
# ログファイルに出力するログレベル (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL_FILE=DEBUG
# ログファイルのローテーション保持日数 (日単位の整数)
LOG_RETENTION_DAYS=14

# 個別ロガーのログレベル設定（オプション）
# 各値を指定するとLOG_LEVEL_FILEのデフォルト値をオーバーライドします。
# 空のままの場合はLOG_LEVEL_FILEの値を使用します。
# 指定可能な値: DEBUG, INFO, WARNING, ERROR, CRITICAL

# アプリケーション全般ログレベル（error.logもこれで制御）
LOG_LEVEL_APP=

# サムネイル再取得ログレベル
LOG_LEVEL_THUMBNAILS=

# YouTube監視ログレベル
LOG_LEVEL_YOUTUBE=

# GUI操作ログレベル
LOG_LEVEL_GUI=

# 投稿エラーログレベル
LOG_LEVEL_POST_ERROR=

# 投稿ログレベル
LOG_LEVEL_POST=

# =============================
# YouTubeAPI連携プラグインの設定
# =============================
# YouTube Data API キー（UC以外のチャンネル識別子対応・ライブ詳細取得に使用）
# YouTubeAPI連携プラグイン未導入時は不要です。
YOUTUBE_API_KEY=

# =============================
# 以下は将来実装予定のプラグイン設定です
# 現在は未実装のため、設定を変更してもアプリケーション動作に影響しません
# =============================

# =============================
# 動画投稿通知機能拡張プラグインの設定（未実装）
# =============================
# YouTube新着動画をBlueskyへ通知するか（True/False）
# NOTIFY_ON_YT_NEWVIDEO=False