
# =============================================
# settings.env.example - 設定ファイルサンプル
#
# このファイルを settings.env にコピーし、必要な値を設定してください。
#
# ⚠️ 注意: settings.env は個人情報（ID・パスワード・APIキー）を含むため、
#         公開リポジトリや共有環境には絶対に含めないでください。
#         また、Git管理外にしてください（.gitignore推奨）。
#
# 必須項目は「=」の右側に値を記入してください。
# サンプル記入例も参考にしてください。
# =============================================

# =============================
# 基本設定
# =============================

# 監視対象のYouTubeチャンネルID
#YouTubeAPI連携プラグイン未導入時はUCから始まるIDのみ設定可能です。
YOUTUBE_CHANNEL_ID=

# アプリケーション動作モード（normal / auto_post / dry_run / collect）
# normal: 完全手動投稿モード（GUI操作で投稿対象を選択）
# auto_post: 完全自動投稿モード（環境変数とロジックのみで制御）
# dry_run: テストモード（投稿実行なし）
# collect: 収集モードのみ（投稿機能オフ）
# 初回起動時やDBが読み込めない場合はcollectモードで起動しDBの再生成を実行します。
APP_MODE=normal

# デバッグモード（true/false）- デバッグ情報を詳細に出力します
DEBUG_MODE=false

# タイムゾーン設定（例: Asia/Tokyo, UTC, America/New_York, Europe/London）
# "system" を指定すると、実行環境のシステムタイムゾーンを自動的に使用します。
# 無効な値や空の場合はシステムタイムゾーンまたはUTCにフォールバックします。
TIMEZONE=system

# =============================
# Bluesky 投稿アカウント設定
# =============================

# Blueskyのユーザー名 (例: your-handle.bsky.social or 独自ドメイン等ご利用中のID)
BLUESKY_USERNAME=

# Blueskyのアプリパスワード (Blueskyの設定画面で発行してください)
BLUESKY_PASSWORD=

# Blueskyへの投稿を有効にするか（True/False）
BLUESKY_POST_ENABLED=True

# -------------------------------------------------- #
# 以下は、v3対応のプラグイン用設定です。
# プラグインを導入しない場合は設定する必要がありません。
# -------------------------------------------------- #

# =============================
# Bluesky 機能拡張プラグインの設定（v3.0.0）
# =============================

# テンプレート機能対応：各プラットフォーム・イベントごとにテンプレートファイルパスを指定
# 未指定時は自動的にデフォルトパス（templates/default/{event}_template.txt）を使用

# YouTube 新着動画投稿用テンプレート
# 用途: 新着動画通知投稿
TEMPLATE_YOUTUBE_NEW_VIDEO_PATH=templates/youtube/yt_new_video_template.txt

# YouTube Live 配信開始通知用テンプレート
# 用途: YouTubeAPI プラグイン連携時の配信開始通知投稿
#TEMPLATE_YOUTUBE_ONLINE_PATH=templates/youtube/yt_online_template.txt

# YouTube Live 配信終了通知用テンプレート
# 用途: YouTubeAPI プラグイン連携時の配信終了通知投稿
#TEMPLATE_YOUTUBE_OFFLINE_PATH=templates/youtube/yt_offline_template.txt

# ニコニコ新着動画投稿用テンプレート
# 用途: RSS 取得によるニコニコ新着動画通知投稿
TEMPLATE_NICO_NEW_VIDEO_PATH=templates/niconico/nico_new_video_template.txt

# Bluesky 投稿時に使用するデフォルト画像ファイルのパス
# 用途: 画像未設定時、または画像ダウンロード失敗時の代替画像
BLUESKY_IMAGE_PATH=images/default/noimage.png

# =============================
# YouTubeAPI連携プラグインの設定
# =============================
# YouTube Data API キー（UC以外のチャンネル識別子対応・ライブ詳細取得に使用）
# YouTubeAPI連携プラグイン未導入時は不要です。
YOUTUBE_API_KEY=

# =============================
# ニコニコ動画プラグインの設定
# =============================

# 監視対象のニコニコユーザーID（数字のみ）
NICONICO_USER_ID=

# ニコニコのユーザー名（テンプレートで投稿者として表示される、省略可）
# 未設定時は自動取得を試みます（優先順位: RSS <dc:creator> > 静画API > ユーザーID）
# - 公開設定や環境によって取得できない場合、環境変数で指定した値が使用されます
# - 確実に名前を指定したい場合、または自動取得が失敗する場合はここに入力してください
NICONICO_USER_NAME=

# ニコニコのポーリング間隔
#（分単位、最小5分=5。例: 10で10分ごと。デフォルト: 10、推奨: 10）
NICONICO_POLL_INTERVAL=10

# =============================
# ログ設定拡張プラグインの設定
# =============================
# グローバルログレベル設定
# コンソール出力するログレベル (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL_CONSOLE=INFO
# ログファイルに出力するログレベル (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL_FILE=INFO
# ログファイルのローテーション保持日数 (日単位の整数)
LOG_RETENTION_DAYS=14

# 個別ロガーのログレベル設定（オプション）
# 各値を指定するとLOG_LEVEL_FILEのデフォルト値をオーバーライドします。
# 空のままの場合はLOG_LEVEL_FILEの値を使用します。
# 指定可能な値: DEBUG, INFO, WARNING, ERROR, CRITICAL

# アプリケーション全般ログレベル（error.logもこれで制御）
LOG_LEVEL_APP=

# 監査ログレベル
LOG_LEVEL_AUDIT=

# サムネイル再取得ログレベル
LOG_LEVEL_THUMBNAILS=

# トンネル接続ログレベル
LOG_LEVEL_TUNNEL=

# YouTube監視ログレベル
LOG_LEVEL_YOUTUBE=

# Niconico監視ログレベル
LOG_LEVEL_NICONICO=

# GUI操作ログレベル
LOG_LEVEL_GUI=

# 投稿エラーログレベル
LOG_LEVEL_POST_ERROR=

# 投稿ログレベル
LOG_LEVEL_POST=
# ====
