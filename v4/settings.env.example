
# =============================================
# settings.env.example - 設定ファイルサンプル
#
# このファイルを settings.env にコピーし、必要な値を設定してください。
#
# ⚠️ 注意: settings.env は個人情報（ID・パスワード・APIキー）を含むため、
#         公開リポジトリや共有環境には絶対に含めないでください。
#         また、Git管理外にしてください（.gitignore推奨）。
#
# 必須項目は「=」の右側に値を記入してください。
# サンプル記入例も参考にしてください。
# =============================================

# =============================
# 基本設定
# =============================

# アプリテーマ（light / dark / system）
# light: 明るいテーマ
# dark: 暗いテーマ
# system: システム設定に合わせる
APP_THEME=dark

# アプリケーション動作モード（selfpost / autopost / dry_run / collect）
# selfpost: 完全手動投稿モード（GUI操作で投稿対象を選択）
# autopost: 完全自動投稿モード（環境変数とロジックのみで制御）
# dry_run: テストモード（投稿実行なし）
# collect: 収集モードのみ（投稿機能オフ）。APP_MODE で明示したときのみ有効
# （DB 未作成時に自動で collect へ切り替えるのは v3 の挙動であり、v4 にはその処理はありません）
# ローカル DB（v4/data/client_v4.db）は起動時に Webhook サーバ側で作成・初期化されます。
APP_MODE=selfpost

# デバッグモード（true/false）- デバッグ情報を詳細に出力します
DEBUG_MODE=False

# タイムゾーン設定（例: Asia/Tokyo, UTC, America/New_York, Europe/London）
# "system" を指定すると、実行環境のシステムタイムゾーンを自動的に使用します。
# 無効な値や空の場合はシステムタイムゾーンまたはUTCにフォールバックします。
TIMEZONE=system

# =============================
# アカウント設定
# =============================

# Bluesky 投稿アカウント設定
# =============================
## Blueskyのユーザー名 (例: your-handle.bsky.social or 独自ドメイン等ご利用中のID)
BLUESKY_USERNAME=neconeco222.bsky.social

## Blueskyのアプリパスワード (Blueskyの設定画面で発行してください)
# 例: id4t-ynqt-37hq-eufn
# ⚠️ 注意: v4.1.x以降はアプリパスワードは非推奨になる予定です。
BLUESKY_PASSWORD=

# Twitch アカウント・APIの設定
# =============================
# Twitchアカウント連携機能はOAuth認証でのみ利用可能です。
# そのため、この項目は設定しても機能しません。
# TWITCH_CLIENT_ID=your_twitch_client_id
# TWITCH_CLIENT_SECRET=your_twitch_client_secret

# YouTube アカウント・APIの設定
# =============================
# 監視対象のYouTubeチャンネルID
# 未設定時はUCから始まるIDのみ設定可能です。
YOUTUBE_CHANNEL_ID=UCOWLA5KwmkTeSo1zVqVA4Sw

# YouTube Data API キー（UC以外のチャンネル識別子対応・ライブ詳細取得に使用）
# 未設定時はサーバー側で処理されます。
# 設定した場合、このキーを使用して名前解決・詳細情報の取得を行います。
YOUTUBE_API_KEY=AIzaSyDXQ9sv3EIJFW0sQgpsPGmh2I5_SlFLXQM

# YouTube フィード取得モード（poll/websub）
# =============================
# RSS ポーリング vs WebSub プッシュ通知を選択

# YouTube フィード取得モード（poll / websub）
# poll: YouTube は RSS のみ。センターサーバー・Twitch EventSub・Bluesky OAuth は使わない（Bluesky は BLUESKY_PASSWORD）
# websub: センター経由で YouTube WebSub / Twitch / Bluesky OAuth（DPoP）を利用
# デフォルト: websub
YOUTUBE_FEED_MODE=websub

# ニコニコ動画の設定
# =============================
# 監視対象のニコニコユーザーID（数字のみ）
NICONICO_USER_ID=24578132

# ニコニコのユーザー名（テンプレートで投稿者として表示される、省略可）
# 未設定時は自動取得を試みます（優先順位: RSS <dc:creator> > 静画API > ユーザーID）
# - 公開設定や環境によって取得できない場合、環境変数で指定した値が使用されます
# - 確実に名前を指定したい場合、または自動取得が失敗する場合はここに入力してください
NICONICO_USER_NAME=まゆにゃ！

# ニコニコのポーリング間隔
#（分単位、最小5分=5。例: 10で10分ごと。デフォルト: 10、推奨: 10）
# NICONICO_POLL_INTERVAL=10
NICONICO_MONITOR_INTERVAL=60

# WebSub 設定
# =============================

# =============================
# 開発・デバッグ設定
# =============================
# ローカルサーバー利用フラグ（true/false、デフォルト: false）
# true に設定すると、CENTER_SERVER_URL の設定に関わらず、強制的にローカルの WebSub センターサーバー (http://localhost:8080) に接続します。
# ※ローカルで v4-websub-server を稼働させてテストを行う場合に使用します。
USE_LOCAL_SERVER=False

# WebSub センターサーバー URL
# YouTube/Twitch の WebSub/EventSub 通知を受信するためのサーバー URL
CENTER_SERVER_URL=https://webhook.neco-server.net

# センター経由の Bluesky OAuth（DPoP / トークン委譲）。false のときは常にアプリパスワード経路。
# センター側で Bluesky ルートを再有効化したら true にできる。
BLUESKY_OAUTH_VIA_CENTER_ENABLED=false

# WebSub クライアント ID
# Webhook リクエストの識別に使用
# 例: my-websub-client-v3
WEBSUB_CLIENT_ID=mayuneco222

# WebSub クライアント API キー
# ※ サーバー要件: 正確に25文字である必要があります
WEBSUB_CLIENT_API_KEY=DBFLjZn94mI7i2Y3RT87LCgXk

# WebSub コールバックベース URL
# センターサーバーからのデータを受け取るためのローカル側のベース URL
WEBSUB_CALLBACK_BASE_URL=http://localhost:20000

# WebSub 購読期間（秒、デフォルト: 432000 = 5日）
# YouTube への購読リクエストで指定する有効期間
# 範囲: 86400（1日）～ 2592000（30日）
# 推奨: 432000（5日）- 定期的に自動更新される
WEBSUB_LEASE_SECONDS=432000

# =============================
# 投稿機能の設定
# =============================

# 投稿保護設定
# =============================
# 重複投稿防止オプション（true/false、デフォルト: false）
# true に設定すると、同じ動画の再投稿を防止します。
# 誤った再投稿の防止、ユーザー体験向上に役立ちます。
PREVENT_DUPLICATE_POSTS=False

# YouTube重複排除オプション（true/false、デフォルト: true）
# true に設定すると、同じタイトル+チャンネルの動画は優先度ベースで管理されます。
# false に設定すると、すべての動画が登録されます。
YOUTUBE_DEDUP_ENABLED=True

# Blueskyへの投稿を有効にするか（True/False）
BLUESKY_POST_ENABLED=True

# AUTOPOST 自動投稿モード設定
# APP_MODE=autopost の場合に有効となる設定項目
# =============================
# YouTube Live 自動投稿モード（AUTOPOST時用設定、デフォルト: off）
# all: 予約枠・配信・アーカイブすべてを投稿
# schedule: 予約枠のみ投稿
# live: 予約枠と配信開始・配信終了のみ投稿
# archive: アーカイブ公開のみ投稿
# 空欄: YouTube Live 関連の自動投稿を行わない
# ⚠️ 注意: この設定は AUTOPOST モード専用です
# ⚠️ SELFPOST モード で YouTube Live を自動投稿するには、下記の個別フラグを使用してください
AUTOPOST_STATUSES=["upcoming", "live", "archive"]

# AUTOPOST 投稿間隔（分、デフォルト: 5、範囲: 1-60）
# 連続投稿によるスパム化を防止します
AUTOPOST_INTERVAL_MINUTES=5

# AUTOPOST LOOKBACK時間窓（分、デフォルト: 30、範囲: 5-1440）
# 再起動時の取りこぼし防止を目的とします
AUTOPOST_LOOKBACK_MINUTES=30

# AUTOPOST 未投稿動画大量検知閾値（件、デフォルト: 20、範囲: 1-1000）
# LOOKBACK時間内に未投稿動画がこの件数以上ある場合、AUTOPOST は起動しません
# これは設定ミスやデバッグ誤爆の兆候を検知する安全弁です
AUTOPOST_MISSED_DETECTION_THRESHOLD=10

# AUTOPOST 投稿対象 - 通常動画を含めるか（true/false、デフォルト: true）
AUTOPOST_INCLUDE_NORMAL=True

# AUTOPOST 投稿対象 - プレミア配信を含めるか（true/false、デフォルト: true）
AUTOPOST_INCLUDE_PREMIERE=True

# YouTube Live 個別投稿モード（SELFPOST モード向け）
# =============================
# APP_MODE がselfpostの場合のYouTube Live関連の挙動を設定します。
# この設定はYouTube動画には適用されず、YouTube Live配信イベントにのみ適用されます。
# YouTube 動画の自動投稿は、AUTOPOSTモード用の設定で制御してください。

# YouTube Live 予約枠（upcoming）を自動投稿するか（true/false、デフォルト: true）
YOUTUBE_LIVE_AUTO_POST_SCHEDULE=True

# YouTube Live 配信中/終了（live/completed）を自動投稿するか（true/false、デフォルト: true）
YOUTUBE_LIVE_AUTO_POST_LIVE=True

# YouTube Live アーカイブ（archive）を自動投稿するか（true/false、デフォルト: true）
YOUTUBE_LIVE_AUTO_POST_ARCHIVE=True

# =============================
# RSS モード機能時の設定
# =============================
# YouTube Live 投稿遅延設定
# =============================
# 配信開始後に投稿する場合の遅延時間設定
# immediate: 配信開始直後に投稿（デフォルト）
# delay_5min: 配信終了後に投稿
# delay_30min: 配信終了後に投稿（30分後）
YOUTUBE_LIVE_POST_DELAY=immediate

# RSS ポーリング間隔設定（pollモード用）
# =============================
# 配信予定枠の予定時刻を検出を有効にする（True/False、デフォルト: True）
# True に設定すると、rssモード時にYouTube Live予約枠の配信予定時刻を検出します。
# 予約枠の配信予定時刻を検出することで、配信開始通知を投稿するタイミングを正確に把握できます。
# websubモードでは、センターサーバーから状態推移情報が提供されるため、この設定は無視されます。
DETECT_SCHEDULED_TIME=True

# YouTube RSS ポーリング間隔（分単位、最小10分、最大60分、デフォルト: 60）
# YOUTUBE_FEED_MODE が poll の場合にのみ有効
# 短時間での頻繁なポーリングはYouTube側からRSS取得制限を受ける可能性があります。
YOUTUBE_MONITOR_INTERVAL=60

# YouTubeLive RSS ポーリング間隔（分単位、最小10分、最大60分、デフォルト: 60）
# YOUTUBE_FEED_MODE が poll の場合にのみ有効
LIVE_MONITOR_INTERVAL=60

# キャッシュの状態に応じて自動的にポーリング間隔を調整します。
# 3段階戦略: ACTIVE（短い）→ COMPLETED（段階拡大）→ ARCHIVE（追跡）→ NO_LIVE（休止）

# ACTIVE 時のポーリング間隔（分単位、デフォルト: 5）
# schedule または live 状態の動画がある場合、この短い固定間隔でポーリング
# 推奨値: 15分（最短） - 配信開始・終了を素早く検知
# ⚠️ 有効範囲: 1～60分
YOUTUBE_LIVE_POLL_INTERVAL_ACTIVE=15

# COMPLETED のみ時：最短確認間隔（分単位、デフォルト: 60）
# completed 状態のみある場合（schedule/live なし）、この最短間隔で確認開始
# 推奨値: 60分（1時間） - 初回確認
# ⚠️ 有効範囲: 30～180分
YOUTUBE_LIVE_POLL_INTERVAL_COMPLETED_MIN=60

# COMPLETED のみ時：最大確認間隔（分単位、デフォルト: 180）
# completed 状態を追跡する場合、段階的にこの最大間隔まで拡大
# 推奨値: 180分（3時間） - archive 化を待つ
# ⚠️ 有効範囲: 30～180分（MIN より大きい値）
YOUTUBE_LIVE_POLL_INTERVAL_COMPLETED_MAX=180

# ARCHIVE 化後の最大追跡回数（回数、デフォルト: 4）
# completed → archive に遷移した動画を何回まで確認するか
# 推奨値: 4回（最大） - 最後まで確認
# ⚠️ 有効範囲: 1～10回
YOUTUBE_LIVE_ARCHIVE_CHECK_COUNT_MAX=4

# ARCHIVE 化後の確認間隔（分単位、デフォルト: 180）
# archive 状態の動画を確認する間隔（上記回数分）
# 推奨値: 180分（3時間） - COMPLETED_MAX と同じ
# ⚠️ 有効範囲: 30～480分
YOUTUBE_LIVE_ARCHIVE_CHECK_INTERVAL=180

# =============================
# Bluesky 投稿テンプレートとデフォルト画像の設定
# =============================

# テンプレート機能対応：各プラットフォーム・イベントごとにテンプレートファイルパスを指定
# 未指定時は自動的にデフォルトパス（templates/default/{event}_template.txt）を使用

# YouTube テンプレート
# =============================
# YouTube 新着動画投稿用テンプレート
# 用途: 新着動画通知投稿
TEMPLATE_YOUTUBE_NEW_VIDEO_PATH=templates/youtube/yt_new_video_template.txt

# YouTube Live 放送枠予約通知用テンプレート
# 用途: 放送枠が立った時（upcoming/schedule状態）の予約通知投稿
TEMPLATE_YOUTUBE_SCHEDULE_PATH=templates/youtube/yt_schedule_template.txt

# YouTube Live 配信開始通知用テンプレート
# 用途: YouTubeAPI 連携時の配信開始通知投稿
TEMPLATE_YOUTUBE_ONLINE_PATH=templates/youtube/yt_online_template.txt

# YouTube Live 配信終了通知用テンプレート
# 用途: YouTubeAPI 連携時の配信終了通知投稿
TEMPLATE_YOUTUBE_OFFLINE_PATH=templates/youtube/yt_offline_template.txt

# YouTube アーカイブ投稿用テンプレート
# 用途: YouTube Live のアーカイブ（録画）が公開された時の通知投稿
# 設定されていない場合は youtube_new_video テンプレートにフォールバック
TEMPLATE_YOUTUBE_ARCHIVE_PATH=templates/youtube/yt_archive_template.txt

# ニコニコ動画 テンプレート
# =============================
# ニコニコ新着動画投稿用テンプレート
# 用途: RSS 取得によるニコニコ新着動画通知投稿
TEMPLATE_NICO_NEW_VIDEO_PATH=templates/niconico/nico_new_video_template.txt

# Twitch テンプレート
# =============================
# Twitch 配信開始通知用テンプレート
# 用途: Twitch 連携時の配信開始通知投稿
TEMPLATE_TWITCH_ONLINE_PATH=templates/twitch/twitch_online_template.txt

# Twitch 配信終了通知用テンプレート
# 用途: Twitch 連携時の配信終了通知投稿
TEMPLATE_TWITCH_OFFLINE_PATH=templates/twitch/twitch_offline_template.txt

# Twitch Raid 通知用テンプレート
# 用途: Raid イベント発生時の通知投稿
TEMPLATE_TWITCH_RAID_PATH=templates/twitch/twitch_raid_template.txt

# デフォルト画像ファイルのパス設定
# =============================
# Bluesky 投稿時に使用するデフォルト画像ファイルのパス
# 用途: 画像未設定時、または画像ダウンロード失敗時の代替画像
BLUESKY_IMAGE_PATH=images/default/noimage.png

# 画像自動リサイズ機能の設定
# =============================
# 横長画像のターゲット幅（ピクセル、デフォルト: 1280）
# 横長画像（幅/高さ >= 1.3）を3:2にリサイズする際のターゲット幅
IMAGE_RESIZE_TARGET_WIDTH=1200

# 横長画像のターゲット高さ（ピクセル、デフォルト: 800）
# 横長画像を3:2にリサイズする際のターゲット高さ
IMAGE_RESIZE_TARGET_HEIGHT=800

# JPEG初期出力品質（1-100、デフォルト: 90）
# リサイズ後のJPEG圧縮品質。値が低いほどファイルサイズが小さくなります
IMAGE_OUTPUT_QUALITY_INITIAL=90

# ファイルサイズ目標値（バイト、デフォルト: 800000）
# 理想的なファイルサイズ（800KB）。ログで参考値として表示されます
IMAGE_SIZE_TARGET=819200

# ファイルサイズ品質低下開始閾値（バイト、デフォルト: 900000）
# この値（900KB）を超えた場合、JPEG品質を段階的に低下させて再圧縮します
IMAGE_SIZE_THRESHOLD=921600

# ファイルサイズ最終上限（バイト、デフォルト: 1000000）
# Bluesky API の上限（1MB）。超過時は画像添付をスキップします
IMAGE_SIZE_LIMIT=1024000

# =============================
# ログ設定拡張の設定
# =============================

# グローバルログレベル設定
# =============================
# コンソール出力するログレベル (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL_CONSOLE=INFO
# ログファイルに出力するログレベル (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL_FILE=INFO
# ログファイルのローテーション保持日数 (日単位の整数)
LOG_RETENTION_DAYS=14

# 個別ロガーのログレベル設定（オプション）
# 各値を指定するとLOG_LEVEL_FILEのデフォルト値をオーバーライドします。
# 空のままの場合はLOG_LEVEL_FILEの値を使用します。
# 指定可能な値: DEBUG, INFO, WARNING, ERROR, CRITICAL

# 認証処理ログレベル
LOG_LEVEL_AUTH=INFO

# Webhook処理ログレベル
LOG_LEVEL_WEBHOOK=INFO

# GUI操作ログレベル
LOG_LEVEL_GUI=INFO

# Bluesky投稿ログレベル
LOG_LEVEL_BSKY=INFO

# Youtube投稿監視レベル
LOG_LEVEL_YOUTUBE=INFO

# Niconico監視ログレベル
LOG_LEVEL_NICONICO=INFO

# Twitch監視ログレベル
LOG_LEVEL_TWITCH=INFO

# サムネイル再取得ログレベル
#LOG_LEVEL_THUMBNAILS=INFO

# 投稿エラーログレベル
#LOG_LEVEL_POST_ERROR=ERROR

# 投稿ログレベル
#LOG_LEVEL_POST=INFO

# =============================
# 以下は将来実装予定の設定です
# 現在は未実装のため、設定を変更してもアプリケーション動作に影響しません
# =============================

# =============================
# 動画投稿通知機能拡張の設定（未実装）
# =============================
# ActivityPubなどへ投稿するか(True/False)
# ACTIVITIPUB_NOTIFY_ENABLED=False
# Discord通知を有効にするか (True/False)
# DISCORD_NOTIFY_ENABLED=False
